{
  "baseUrl": "http://localhost:8080",
  "token": "STAGING_TOKEN",
  "authMode": "token",
  "auth": {
    "loginPath": "/auth/login",
    "logoutPath": "/auth/logout",
    "tokenHeader": "Authorization",
    "tokenPrefix": "Bearer "
  },
  "minPostBytes": 10000,
  "errorMixEnabled": true,
  "errorMixWeights": {
    "notFound": 40,
    "unauthorized": 20,
    "serverError": 15,
    "nonJson": 15,
    "timeout": 10
  },
  "errorPaths": {
    "notFound": "/__not_found__",
    "unauthorized": "/users/me",
    "serverError": "/__server_error__",
    "nonJson": "/__non_json__",
    "timeout": "/__timeout__"
  },
  "errorTimeout": {
    "request": "1s"
  },
  "ws": {
    "messageIntervalMs": 200,
    "sessionMs": 5000,
    "payloadBytes": 64,
    "roomCount": 5,
    "soakMs": 600000
  },
  "thresholds": {
    "http_req_failed": ["rate<0.01"],
    "http_req_duration": ["p(95)<300"]
  }
}
